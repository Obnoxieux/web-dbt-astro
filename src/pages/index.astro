---
import { getCollection } from "astro:content";
import CodeExampleSection from "../components/astro/code/CodeExampleSection.astro";
import Layout from "../layouts/Layout.astro";
import { OpenGraphDefaults } from "../lib/classes/OpenGraphDefaults";
import { Image } from "astro:assets";
import fakeCodePhoto from "../assets/images/fake_code_photo.webp";

const pageTitle = "Main";
const metaTags = {
  title: pageTitle,
  openGraph: OpenGraphDefaults.getOpenGraphObject(
    Astro.url,
    pageTitle,
    OpenGraphDefaults.description,
  ),
};

const languages = await getCollection("languages");
---

<Layout title={pageTitle} metaTags={metaTags}>
  <article class="hero card card-prominent">
    <div class="hero-content">
      <div class="hero-text-block">
        <h1 class="">David the Dev</h1>
        <p class="py-6">
          I transform zeros, ones and caffeine into [object Object].
        </p>
        <a href="/contact" class="btn btn-neutral">Get in touch</a>
      </div>

      <figure class="hero-figure">
        <Image
          src={fakeCodePhoto}
          class="hero-image"
          alt="IDE with code on a dark screen"
        />
        <figcaption>
          <i>
            Obviously I am much better at writing code than taking pictures of
            it. Just kidding.
          </i>
        </figcaption>
      </figure>
    </div>
  </article>

  <div class="middle-grid">
    <article class="link-card card card-prominent">
      <h2 class="card-title">My Work</h2>
      <p>Technologies, frameworks and what I build with them</p>
      <div class="card-actions">
        <a href="/tech" class="button">Go to section</a>
      </div>
    </article>

    <article class="link-card card card-prominent">
      <h2 class="card-title">My Blog</h2>
      <p>The stuff that nobody reads</p>
      <div class="card-actions">
        <a href="/blog" class="button">Go to section</a>
      </div>
    </article>

    <article class="link-card card card-prominent">
      <h2 class="card-title">Open source</h2>
      <p>Giving back to the Free Software community</p>
      <div class="card-actions">
        <a href="/tech/foss" class="button">Go to section</a>
      </div>
    </article>
  </div>

  <CodeExampleSection codeSamples={languages.map((lang) => lang.data)} />
</Layout>

<style>
  .hero-content {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-6);
    place-content: center;

    @media (min-width: 32rem) {
      grid-template-columns: 1fr 1fr;
    }
  }

  .card-title {
    margin-block-end: 0;
  }

  .middle-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-6);
    justify-items: center;
    margin-block: var(--space-8);
    grid-template-rows: repeat(3, auto);

    @media (min-width: 48rem) {
      grid-template-columns: 1fr 1fr 1fr;
    }
  }

  .link-card {
    display: grid;
    grid-template-rows: subgrid;
    grid-row: span 3;
    width: 100%;

    .card-actions {
      display: flex;
      justify-content: flex-end;
    }
  }
</style>
