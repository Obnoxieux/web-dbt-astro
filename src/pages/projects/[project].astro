---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import ProjectDetailIntro from "../../components/projects/ProjectDetailIntro.astro";
import { render } from "astro:content";
import ProjectDetailLinkSection from "../../components/projects/ProjectDetailLinkSection.astro";
import ProjectDetailMainContainer from "../../components/projects/ProjectDetailMainContainer.astro";

export async function getStaticPaths() {
  const projects = await getCollection("projects");
  return projects.map((project) => ({
    params: { project: project.id },
    props: { project: project },
  }));
}

const { project } = Astro.props;
const { Content } = await render(project);
---

<Layout title={project.data.name} description={project.data.description}>
  <ProjectDetailIntro project={project} />
  <hr />
  <Content />
  <ProjectDetailMainContainer project={project} />
  <ProjectDetailLinkSection project={project} />
</Layout>
