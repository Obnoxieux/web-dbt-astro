---
import type { CodeLanguage } from "astro";
import { Code } from "astro:components";

interface Props {
  lang: CodeLanguage;
  code: string;
  theme?: string;
}
const { lang, code, theme = "one-dark-pro" } = Astro.props;
---

<div class="code-block col-span-2">
  {/*@ts-ignore */}
  <Code lang={lang} code={code} theme={theme} />
</div>

<style>
  .code-block {
    pre {
      border-radius: 0.5rem;
      padding: 0 0.5rem 0.5rem;
    }
  }
</style>
